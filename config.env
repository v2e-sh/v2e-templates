# v2e template builder — host-side config (sourced by build-*.sh). Edit per host.
# Everything runs ON the Proxmox host as root via qm + virt-customize.
# No Proxmox API token, no build network, no Packer.

# ---- Proxmox placement ----
STORAGE="local-lvm"                  # VM disk + cloud-init drive storage
BRIDGE="vmbr0"                       # template NIC bridge (cloud-init sets per-clone IPs)
IMG_CACHE="/var/lib/vz/template/iso" # where base images are downloaded + cached

# ---- Baked tool versions ----
SOPS_VERSION="3.9.4"
AGE_VERSION="1.2.1"

# ---- Per-image: VMID, template name, base image URL + sha256 ----
# The Ubuntu/Debian "release"/"latest" URLs track the newest point release. If upstream
# publishes a newer image, the sha256 check fails loudly — update the sha256 here (or pin
# a dated URL) to refresh. VMIDs are the STAGING range (9900-9903); promote to 9000-9003.

UBUNTU_VMID="9901"
UBUNTU_NAME="ubuntu-2404-pk"
UBUNTU_URL="https://cloud-images.ubuntu.com/releases/24.04/release/ubuntu-24.04-server-cloudimg-amd64.img"
UBUNTU_SHA256="5fa5b05e5ec239858c4531485d6023b0896448c2df7c63b34f8dae6ea6051a44"

DEBIAN_VMID="9902"
DEBIAN_NAME="debian-13-pk"
DEBIAN_URL="https://cloud.debian.org/images/cloud/trixie/latest/debian-13-genericcloud-amd64.qcow2"
DEBIAN_SHA256="e32d03ec8f05b0b3a4c16e8cc0a5424efa78514141a60a2656623cf422cc6416"

# Parrot Home is a large (~5GB) desktop qcow2; auto-fetch works but is slow. If the URL
# changes, download it once into IMG_CACHE manually and the build reuses it.
PARROT_VMID="9903"
PARROT_NAME="parrot-home-pk"
PARROT_URL="https://deb.parrot.sh/parrot/iso/7.2/Parrot-home-7.2_amd64.qcow2"
PARROT_SHA256="298ae67c60a3b60d1927a768792ada83c3d7b321158304653f45f62a0b3e9876"

# VyOS — no cloud image upstream, so it is built FROM SOURCE (rolling) by
# vyos/build-from-source.sh (a throwaway Debian builder VM runs vyos-build). That writes
# vyos-<branch>.qcow2 into IMG_CACHE; build-vyos.sh then imports it (no virt-customize —
# the router needs no sops/age).
#   - Trust-me users: set VYOS_URL to a published qcow2 (e.g. a GitHub release asset) +
#     VYOS_SHA256, and build-vyos.sh fetches it instead of needing the source build.
#   - DIY users: leave VYOS_URL empty and run vyos/build-from-source.sh first.
# LTS (sagitta/circinus) needs a VyOS subscription mirror; rolling (current) is free.
VYOS_VMID="9900"
VYOS_NAME="vyos-pk"
VYOS_BRANCH="current"
VYOS_URL="https://github.com/v2e-sh/v2e-templates/releases/download/vyos-rolling-202606302015/vyos-current.qcow2"
VYOS_SHA256="7b0e97b889a60d7b2014dbad8bf8141dc47d333c4589b4b60f377178d497cf87"
# builder VM (throwaway) — clones the Debian template, needs internet via the host NAT
VYOS_BUILDER_VMID="9990"
VYOS_BUILDER_IP="10.0.0.50" # EDIT: a free static IP on BRIDGE for the throwaway builder VM
BUILD_GW="10.0.0.1"         # EDIT: gateway with internet for the builder (e.g. the host if it NATs)
